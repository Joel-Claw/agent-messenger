{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Agent Messenger server monitoring dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Connected Agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "agent_messenger_agents_connected", "legendFormat": "Agents", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 3 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "No Agents", "color": "red" } } }]
        }
      }
    },
    {
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "agent_messenger_clients_connected", "legendFormat": "Clients", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      }
    },
    {
      "title": "Offline Queue Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "agent_messenger_offline_queue_depth", "legendFormat": "Queued", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
        }
      }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [{ "expr": "rate(agent_messenger_errors_total[5m])", "legendFormat": "errors/sec", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "Stale Agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{ "expr": "agent_messenger_stale_agents", "legendFormat": "Stale", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{ "expr": "agent_messenger_uptime_seconds", "legendFormat": "Uptime", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Message Throughput",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Messages In/Out",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "rate(agent_messenger_messages_in_total[5m])", "legendFormat": "In/sec", "refId": "A" },
        { "expr": "rate(agent_messenger_messages_out_total[5m])", "legendFormat": "Out/sec", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "title": "Error & Rate Limit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "rate(agent_messenger_errors_total[5m])", "legendFormat": "Errors/sec", "refId": "A" },
        { "expr": "rate(agent_messenger_rate_limited_total[5m])", "legendFormat": "Rate Limited/sec", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "title": "Connections",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        { "expr": "agent_messenger_agents_connected", "legendFormat": "Agents", "refId": "A" },
        { "expr": "agent_messenger_clients_connected", "legendFormat": "Clients (unique)", "refId": "B" },
        { "expr": "agent_messenger_client_conns_total", "legendFormat": "Client Conns (total)", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "title": "Connection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        { "expr": "rate(agent_messenger_connections_total[5m])", "legendFormat": "Connections/sec", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "title": "Resources",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        { "expr": "agent_messenger_memory_alloc_bytes", "legendFormat": "Allocated", "refId": "A" },
        { "expr": "agent_messenger_memory_sys_bytes", "legendFormat": "System", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "title": "Goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "agent_messenger_goroutines", "legendFormat": "Goroutines", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20 } }
      }
    },
    {
      "title": "Offline Queue",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "title": "Queue Depth Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "targets": [
        { "expr": "agent_messenger_offline_queue_depth", "legendFormat": "Queued Messages", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20 } }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["agent-messenger", "messaging"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Agent Messenger",
  "uid": "agent-messenger",
  "version": 1
}