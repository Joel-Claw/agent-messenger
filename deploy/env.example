# Agent Messenger deployment environment
# Copy to /etc/agent-messenger/env and fill in your values

# === Authentication ===
# JWT signing secret — MUST be changed in production!
JWT_SECRET=change-me-to-a-random-secret

# Shared secret for agent authentication — MUST be changed in production!
AGENT_SECRET=change-me-to-a-random-secret

# Admin secret for /admin/* endpoints — MUST be changed in production!
ADMIN_SECRET=change-me-to-a-random-secret

# === Server ===
PORT=8080

# Database — set DATABASE_URL for PostgreSQL, or DB_PATH for SQLite
DB_PATH=/var/lib/agent-messenger/agent-messenger.db
# DATABASE_URL=postgres://user:pass@localhost:5432/agent_messenger
# DB_DRIVER=postgres

# CORS — comma-separated origins, or * for all (development only)
CORS_ALLOWED_ORIGINS=*

# Max upload size (supports B, KB, MB, GB, TB — default 10MB)
MAX_UPLOAD_SIZE=10MB

# === Agent Heartbeat ===
# Enable agent presence heartbeat monitoring
AGENT_HEARTBEAT_ENABLED=false
# AGENT_HEARTBEAT_INTERVAL=30s
# AGENT_HEARTBEAT_TIMEOUT=90s

# === Push Notifications ===
# APNs (iOS) — leave empty if not using iOS
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=

# FCM (Android) — leave empty if not using Android
FCM_SERVICE_ACCOUNT=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# === WebChat ===
# Enable serving WebChat static files from the Go server
# WEBCHAT_ENABLED=true
# WEBCHAT_DIR=/path/to/webchat/build