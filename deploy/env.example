# Agent Messenger deployment environment
# Copy to /etc/agent-messenger/env and fill in your values

# === Authentication ===
# JWT signing secret — MUST be changed in production!
JWT_SECRET=change-me-to-a-random-secret

# Shared secret for agent authentication — MUST be changed in production!
AGENT_SECRET=change-me-to-a-random-secret

# Admin secret for /admin/* endpoints — MUST be changed in production!
ADMIN_SECRET=change-me-to-a-random-secret

# === Server ===
PORT=8080

# Database — set DATABASE_URL for PostgreSQL, or DB_PATH for SQLite
DB_PATH=/var/lib/agent-messenger/agent-messenger.db
# DATABASE_URL=postgres://user:pass@localhost:5432/agent_messenger
# DB_DRIVER=postgres

# Database connection pool (PostgreSQL only)
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=30m
# DB_CONN_MAX_IDLE_TIME=5m

# CORS — comma-separated origins, or * for all (development only)
CORS_ALLOWED_ORIGINS=*

# Max upload size (supports B, KB, MB, GB, TB — default 10MB)
MAX_UPLOAD_SIZE=10MB

# Max WebSocket message size in bytes (default 65536 = 64KB)
# MAX_WS_MESSAGE_SIZE=65536

# === Agent Heartbeat ===
# Enable agent presence heartbeat monitoring
AGENT_HEARTBEAT_ENABLED=false
# AGENT_HEARTBEAT_INTERVAL=30s
# AGENT_HEARTBEAT_TIMEOUT=90s

# === Push Notifications ===
# APNs (iOS) — leave empty if not using iOS
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=

# FCM (Android) — leave empty if not using Android
FCM_SERVICE_ACCOUNT=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# === WebChat ===
# Enable serving WebChat static files from the Go server
# WEBCHAT_ENABLED=true
# WEBCHAT_DIR=/path/to/webchat/build

# === Observability (OpenTelemetry) ===
# Enable OpenTelemetry tracing (default: false)
# OTEL_ENABLED=true
# OTLP collector endpoint (e.g., "localhost:4317" for gRPC, "localhost:4318" for HTTP)
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# Protocol: "grpc" (default) or "http"
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# Service name in traces (default: "agent-messenger")
# OTEL_SERVICE_NAME=agent-messenger
# Sampling rate 0.0-1.0 (default: 0.1 = 10%)
# OTEL_SAMPLING_RATE=0.1

# === Logging ===
# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# === Rate Limiting ===
# General per-IP rate limit (requests per minute, default: 300)
# IP_RATE_LIMIT=300
# Auth endpoint per-IP rate limit (default: 30/min)
# AUTH_RATE_LIMIT=30