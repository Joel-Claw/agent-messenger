# Agent Messenger deployment environment
# Copy to /etc/agent-messenger/env and fill in your values

JWT_SECRET=change-me-to-a-random-secret
PORT=8080
DB_PATH=/var/lib/agent-messenger/agent-messenger.db

# CORS — comma-separated origins, or * for all (development only)
CORS_ALLOWED_ORIGINS=*

# Max upload size (supports B, KB, MB, GB, TB — default 10MB)
MAX_UPLOAD_SIZE=10MB

# APNs (iOS push notifications) — leave empty if not using iOS
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=

# FCM (Android push notifications) — leave empty if not using Android
FCM_SERVICE_ACCOUNT=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=