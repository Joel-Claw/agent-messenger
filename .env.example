# Agent Messenger - Docker Compose Environment
# Copy to .env and fill in your values

# Required: JWT secret for signing tokens (use a long random string)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Server port (default: 8080)
PORT=8080

# APNs (iOS push) — leave blank if not using iOS
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=

# FCM (Android push) — leave blank if not using Android
FCM_SERVICE_ACCOUNT=